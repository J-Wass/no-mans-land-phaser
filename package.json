{
  "name": "phaser-game",
  "version": "1.0.0",
  "description": "A Phaser 3 game project",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "keywords": [
    "phaser",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "phaser3-rex-plugins": "^1.80.20"
  }
}
